# Copie ce fichier en .env et adapte les valeurs.

# Clé secrète Django (génère-en une nouvelle en prod).
SECRET_KEY=dev-secret-change-me

# 1 = mode développement (autorise l'auth de dev sans Firebase).
DEBUG=1

# Hôtes autorisés (séparés par des virgules) en prod.
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données. Vide = SQLite (dev). En prod : URL PostgreSQL, ex :
# DATABASE_URL=postgres://user:password@host:5432/fintrack
DATABASE_URL=

# Chemin vers la clé de compte de service Firebase (pour vérifier les tokens).
# Télécharge-la depuis la console Firebase (Paramètres > Comptes de service).
# Laisse vide en dev pour utiliser l'auth de développement.
FIREBASE_CREDENTIALS=

# Origines autorisées pour CORS (séparées par des virgules). Vide = tout (dev).
CORS_ALLOWED_ORIGINS=
